{
  "name": "themenear",
  "version": "1.0.0",
  "description": "NearTrips — Premium Travel Booking WordPress Theme",
  "scripts": {
    "dev": "tailwindcss -i ./assets/css/src/tailwind.css -o ./assets/css/tailwind.css --watch",
